generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  USER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  bookings  Booking[]
}

model Event {
  id             String    @id @default(cuid())
  title          String
  description    String
  location       String
  date           DateTime
  capacity       Int
  availableSeats Int
  price          Float
  image          String?
  createdAt      DateTime  @default(now())
  bookings       Booking[]
}

model Booking {
  id       String        @id @default(cuid())
  userId   String
  eventId  String
  status   BookingStatus @default(PENDING)
  bookedAt DateTime      @default(now())
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  event    Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}
